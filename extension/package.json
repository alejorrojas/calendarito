{
  "name": "calendarito-extension",
  "displayName": "Calendarito",
  "version": "0.1.0",
  "description": "Add events to Google Calendar from anywhere.",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.4",
    "framer-motion": "^11.0.0",
    "lucide-react": "^0.475.0",
    "plasmo": "^0.90.5",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.268",
    "@types/node": "^20.11.5",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "autoprefixer": "^10.4.17",
    "postcss": "^8.4.33",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3"
  },
  "manifest": {
    "name": "Calendarito",
    "description": "Add events to Google Calendar from anywhere.",
    "permissions": ["cookies", "storage", "sidePanel"],
    "host_permissions": [
      "https://calendarito.com/*",
      "https://*.supabase.co/*",
      "https://www.googleapis.com/*"
    ],
    "side_panel": {
      "default_path": "sidepanel.html"
    },
    "action": {
      "default_title": "Open Calendarito"
    }
  }
}
